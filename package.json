{
  "name": "teawind-engine",
  "version": "1.0.0",
  "description": "Lightweight utility-first CSS engine",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui"
  },
  "vitest": {
    "environment": "jsdom",
    "globals": true,
    "include": [
      "test/**/*.test.js"
    ]
  },
  "devDependencies": {
    "vitest": "^1.6.0",
    "jsdom": "^23.0.0",
    "@vitest/ui": "^1.6.0"
  },
  "keywords": [
    "css",
    "utility",
    "teawind",
    "tailwind"
  ],
  "author": "Ravindra Dhadave",
  "license": "MIT"
}
